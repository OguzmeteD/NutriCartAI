#!/usr/bin/env bash
# Usage: ./tf <terraform command and args>
# Example: ./tf plan
#          ./tf apply -auto-approve
#          ./tf -chdir=bootstrap apply

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$SCRIPT_DIR/.env"

if [[ ! -f "$ENV_FILE" ]]; then
  echo "ERROR: $ENV_FILE not found. Copy .env.example and fill in your credentials." >&2
  exit 1
fi

# Export all variables from .env (skip comments and blank lines)
set -a
# shellcheck source=/dev/null
source "$ENV_FILE"
set +a

exec terraform "$@"
